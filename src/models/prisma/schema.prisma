generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int        @id @default(autoincrement())
  name         String
  email        String     @unique
  password     String
  role         String     @default("USER") // USER or ADMIN
  token        String?    // Active JWT token for session management
  profileImage String?
  fullName     String?
  phone        String?
  address      String?
  landmark     String?
  pincode      String?
  state        String?
  city         String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?
  orders       Order[]
  wishlists    Wishlist[]
}

model Product {
  id           Int      @id @default(autoincrement())
  title        String
  description  String
  price        Float
  category     String
  images       String[] // Array of image paths/URLs
  colors       String[] // Array of hex codes or color names
  sizes        String[] // Array of sizes like S, M, L, XL
  rating       Float    @default(5.0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  reviews      Review[]
  wishlists    Wishlist[]
}

model Review {
  id        Int      @id @default(autoincrement())
  rating    Int      // 1 to 5 stars
  comment   String
  userName  String
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([productId])
}

model Order {
  id            Int      @id @default(autoincrement())
  userId        Int
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalAmount   Float
  items         Json     // Array of bought items with quantity, color, size, title, price
  status        String   @default("BOOKED") // BOOKED, DELIVERED, CANCELLED
  paymentMethod String   @default("COD")
  fullName      String?
  email         String?
  phone         String?
  address       String?
  landmark      String?
  pincode       String?
  state         String?
  city          String?
  createdAt     DateTime @default(now())

  @@index([userId])
}

model Wishlist {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@unique([userId, productId])
}

model Settings {
  id          Int    @id @default(1)
  companyName String @default("MDFK CLOTHING CO.")
  logoUrl     String @default("/logo.jpg")
}

model Coupon {
  id             Int       @id @default(autoincrement())
  code           String    @unique
  discountAmount Float                    // Flat discount in ₹ (30-40)
  minOrderAmount Float     @default(499)  // Minimum order value to apply
  isUsed         Boolean   @default(false)
  usedByUserId   Int?
  usedAt         DateTime?
  expiresAt      DateTime
  createdAt      DateTime  @default(now())

  @@index([code])
  @@index([isUsed])
}

model OfferClaim {
  id             Int       @id @default(autoincrement())
  userId         Int       @unique          // One claim per user
  discountAmount Float                      // ₹30-40 random discount
  isUsed         Boolean   @default(false)  // Used in an order?
  usedAt         DateTime?
  createdAt      DateTime  @default(now())
}


